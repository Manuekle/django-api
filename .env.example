# Copiá este archivo a `.env` y ajustá los valores.
# `.env` está en .gitignore: nunca lo subas al repo.

# Clave secreta de Django (generá una nueva para producción).
SECRET_KEY=django-insecure-dev-key-cambiame-en-produccion

# Modo debug: True en desarrollo, False en producción.
DEBUG=True

# Hosts permitidos, separados por coma.
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Base de datos (opcional) ---------------------------------------------
# Por defecto se usa SQLite y no hace falta nada de esto.
# Descomentá y completá si cambiás a MySQL/Postgres en settings.py.
# DB_NAME=api
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306
